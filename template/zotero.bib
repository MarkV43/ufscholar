
@inproceedings{santos_da_silva_discrete_2019,
	title = {Discrete {SPS} Control of a {DAB} converter using partial Feedback Linearization},
	url = {https://ieeexplore.ieee.org/document/9065814},
	doi = {10.1109/COBEP/SPEC44138.2019.9065814},
	abstract = {This article presents the design and evaluation of a discrete non-linear controller with bilinear approximation to regulate the output voltage of a Dual Active Bridge ({DAB}) converter under parametric uncertainties. In this paper we consider the possible uncertainties in the system, such as variations in load and input voltage. The drive is controlled by single phase shift modulation ({SPS}) with a fixed duty cycle. The discrete controller developed ensures disturbance rejection, reference tracking and zero overshoot, with a small transient regime. The results obtained through the Typhoon {HIL} are presented to validate the effectiveness of the developed controller.},
	eventtitle = {2019 {IEEE} 15th Brazilian Power Electronics Conference and 5th {IEEE} Southern Power Electronics Conference ({COBEP}/{SPEC})},
	pages = {1--6},
	booktitle = {2019 {IEEE} 15th Brazilian Power Electronics Conference and 5th {IEEE} Southern Power Electronics Conference ({COBEP}/{SPEC})},
	author = {Santos da Silva, Eduardo Luiz and Luís Kirsten, André and Pagano, Daniel Juan},
	urldate = {2025-09-04},
	date = {2019-12},
	note = {{ISSN}: 2643-9778},
	keywords = {Capacitors, {DAB} converter, Discrete Modeling, Feedback Linearization Control, Feedback linearization, Hardware in the loop, Inductors, Load modeling, Mathematical model, Modulation, Nonlinear control, Switches},
}

@article{kong_transient_2025,
	title = {Transient {DC} Offset Mitigation for Dual Active Bridge Converters Based on Model Predictive Control With Optimized Dynamic Performance},
	volume = {72},
	rights = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/{IEEE}.html},
	issn = {0278-0046, 1557-9948},
	url = {https://ieeexplore.ieee.org/document/10745984/},
	doi = {10.1109/TIE.2024.3482096},
	abstract = {Transient dc offset and the relevant high current impact are crucial for dual active bridge ({DAB}) converters. Many previous works require additional resources or complicated implementations. Furthermore, the tradeoff between dynamic performance and the mitigation of dc offset is challenging. A fast dynamic response and a mild dc offset are usually contradictory. To address the current state of research, this article proposes a mitigation method based on model predictive control. Herein, the adjusting subshift angles are calculated based on predictive value and current value. The implementation is easy, and fast dynamics are achieved. Moreover, to address the unexpected current impact caused by the sharp changed shift angles of {MPC}, an optimization for transient state is proposed. The maximum output power matching references is released as much as possible, provided that the resulting current impact remains below the speciﬁed safety threshold. These methods give {DABs} a fast response speed with no dc offset and release the maximum power while limiting the current impact. Finally, the experimental comparisons with other schemes verify the effectiveness and superiority of the proposed method.},
	pages = {5906--5916},
	number = {6},
	journaltitle = {{IEEE} Transactions on Industrial Electronics},
	shortjournal = {{IEEE} Trans. Ind. Electron.},
	author = {Kong, Dehao and Wang, Yongdu and Zhang, Zhenbin and Rodriguez, Jose and Kennel, Ralph and Heldwein, Marcelo Lobo},
	urldate = {2025-09-04},
	date = {2025-06},
	langid = {english},
}

@inproceedings{fraytag_impacts_2019,
	location = {Santos, Brazil},
	title = {Impacts of the Multi-Variables Modulation on Transformer and Soft-Switching of a {DAB}},
	rights = {https://ieeexplore.ieee.org/Xplorehelp/downloads/license-information/{IEEE}.html},
	isbn = {978-1-7281-4180-0},
	url = {https://ieeexplore.ieee.org/document/9065807/},
	doi = {10.1109/COBEP/SPEC44138.2019.9065807},
	abstract = {Due to the current importance of Dual-{ActiveBridge} ({DAB}) converters, this work proposes an analysis framework to model the {DAB} static behavior when it is subjected to a multi-variables modulation. In this type of modulation, in addition to the angular-phase-shift between the {DAB} H-bridges, the primary and secondary-side voltage duty-cycles can also be varied. The current analysis proposes tools to deﬁne the most suitable operation point for a {DAB} converter, analyzing the impact of choosing this operating point on the transformer and switches. In this context, magnetic core volume, copper losses and soft-switching are considered. Experimental results for a 800 W prototype are presented to validate the proposed analyzes.},
	eventtitle = {2019 {IEEE} 15th Brazilian Power Electronics Conference and 5th {IEEE} Southern Power Electronics Conference ({COBEP}/{SPEC})},
	pages = {1--6},
	booktitle = {2019 {IEEE} 15th Brazilian Power Electronics Conference and 5th {IEEE} Southern Power Electronics Conference ({COBEP}/{SPEC})},
	publisher = {{IEEE}},
	author = {Fraytag, Jeferson and Kirsten, Andre Luis and Lobo Heldwein, Marcelo},
	urldate = {2025-09-04},
	date = {2019-12},
	langid = {english},
}

@article{fraytag_impact_2020,
	title = {Impact analysis of a multi‐variables modulation on the transformer of the dual‐active‐bridge converter},
	volume = {13},
	issn = {1755-4535, 1755-4543},
	url = {https://ietresearch.onlinelibrary.wiley.com/doi/10.1049/iet-pel.2019.0963},
	doi = {10.1049/iet-pel.2019.0963},
	abstract = {Due to the current importance of the Dual-Active-Bridge converter ({DAB}), this work proposes a novel analysis framework to model the {DAB} static behavior when it is subjected to a multi-variables modulation. In this type of modulation, in addition to the angular-phase-shift, the primary and secondary-side voltage duty-cycles can also be varied. The proposed analysis tools are based on the deﬁnition of different operational cases that ultimately deﬁne the converter waveforms when changing phase-shift and duty-cycles. The analysis leads to a map that deﬁnes which the most suitable operation point is for a {DAB}. Novel equations that relate the transferred active power and the total transformer apparent power are derived and an iterative process is proposed, which determines all phase-shift and duty-cycle conditions that lead to a given transferred active power level. An exemplary use is discussed, where the objective was to derive total apparent power maps for a given active power level and ﬁnd the lowest apparent power points. These reduce transformer volume and copper losses, which are discussed for the example at hand. Experimental results at 800 W and 1200 W of a {DAB} prototype are presented to validate the proposed analyzes.},
	pages = {1041--1050},
	number = {5},
	journaltitle = {{IET} Power Electronics},
	shortjournal = {{IET} Power Electronics},
	author = {Fraytag, Jeferson and Kirsten, André Luís and Heldwein, Marcelo Lobo},
	urldate = {2025-09-04},
	date = {2020-04},
	langid = {english},
}

@article{deshmukh_high-accuracy_2024,
	title = {High-Accuracy Generalized Average Model of Dual Active Bridge Converters},
	volume = {5},
	rights = {https://creativecommons.org/licenses/by/4.0/legalcode},
	issn = {2644-1314},
	url = {https://ieeexplore.ieee.org/document/10483254/},
	doi = {10.1109/OJPEL.2024.3382808},
	abstract = {This article presents a detailed procedure for deriving the generalized average model ({GAM}) of a dual active bridge converter. The proposed model incorporates higher orders of harmonic components to increase accuracy. Moreover, the turn ratio of the high-frequency transformer (Nt) is considered for realistic modeling, which removes the conventional assumption of unity turn ratio. A detailed model of the {DAB} will ensure an accurate control design. Required mathematical expressions are derived and explained thoroughly, with an example showcasing a {GAM} model of the {DAB} converter up to the ninth harmonics. Several {GAM} models using different harmonic orders (ﬁrst, third, ﬁfth, seventh, and ninth harmonics) are derived and compared to the {PLECS} simulation model and a real-time simulation of the {DAB} converter on the {PLECS} {RT}-Box-2. Results show that including up to the ninth harmonics in the proposed model of the {DAB} converter leads to achieving accurate voltage and current amplitudes that are almost identical to the simulation outputs and even better than the experimental results.},
	pages = {452--460},
	journaltitle = {{IEEE} Open Journal of Power Electronics},
	shortjournal = {{IEEE} Open J. Power Electron.},
	author = {Deshmukh, Rohan Shailesh and Bauer, Pavol and Vahedi, Hani},
	urldate = {2025-09-04},
	date = {2024},
	langid = {english},
}

